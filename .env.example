OPENROUTER_API_KEY=key-here

# Despite the name, this enables WEB interface (not Flask specifically!)
FLASK_ENABLED=True

# S3-compatible storage for log uploads (works with MinIO, CloudFlare R2, AWS S3)
S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET_NAME=amongus-game-logs
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
